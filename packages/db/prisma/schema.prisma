generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id          String   @id @default(uuid())
  email       String   @unique
  fullName    String?
  dateOfBirth DateTime? @db.Date @map("date_of_birth")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sessions       Session[]
  userTopics     UserTopic[]
  userFlashcards UserFlashcard[]

  @@map("profiles")
}

model Topic {
  id            String   @id @default(uuid())
  title         String
  description   String
  level         String   @default("B2")
  category      String
  talkingPoints String[] @default([]) @map("talking_points")
  createdAt     DateTime @default(now()) @map("created_at")

  sessions   Session[]
  flashcards Flashcard[]
  userTopics UserTopic[]

  @@map("topics")
}

model UserTopic {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  topicId   String   @map("topic_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  Profile @relation(fields: [userId], references: [id])
  topic Topic   @relation(fields: [topicId], references: [id])

  @@unique([userId, topicId])
  @@map("user_topics")
}

model Flashcard {
  id        String   @id @default(uuid())
  topicId   String   @map("topic_id")
  type      String
  front     String
  back      String
  createdAt DateTime @default(now()) @map("created_at")

  topic          Topic           @relation(fields: [topicId], references: [id])
  userFlashcards UserFlashcard[]

  @@map("flashcards")
}

model UserFlashcard {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  flashcardId String   @map("flashcard_id")
  ease        Float    @default(2.5)
  interval    Int      @default(1)
  nextReview  DateTime @default(now()) @map("next_review")
  reviewCount Int      @default(0) @map("review_count")
  createdAt   DateTime @default(now()) @map("created_at")

  user      Profile   @relation(fields: [userId], references: [id])
  flashcard Flashcard @relation(fields: [flashcardId], references: [id])

  @@unique([userId, flashcardId])
  @@map("user_flashcards")
}

model Session {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  topicId    String   @map("topic_id")
  audioUrl   String?  @map("audio_url")
  transcript String?
  status     String   @default("recording")
  createdAt  DateTime @default(now()) @map("created_at")

  user     Profile    @relation(fields: [userId], references: [id])
  topic    Topic      @relation(fields: [topicId], references: [id])
  feedback Feedback[]
  messages Message[]

  @@map("sessions")
}

model Feedback {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  type      String
  content   Json
  turn      Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])

  @@map("feedback")
}

model Message {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  role      String
  content   String
  turn      Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])

  @@map("messages")
}
